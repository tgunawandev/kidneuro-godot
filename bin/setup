#!/usr/bin/env bash
# =============================================================================
# setup - KidNeuro Initial Project Setup
# Usage: ./bin/setup
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
cd "$PROJECT_DIR"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'

info()  { echo -e "${BLUE}[INFO]${NC} $*"; }
ok()    { echo -e "${GREEN}[  OK]${NC} $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
err()   { echo -e "${RED}[FAIL]${NC} $*" >&2; }

echo -e "${CYAN}"
echo "  _  ___     _ _   _                      "
echo " | |/ (_)   | | \\ | |                     "
echo " | ' / _  __| |  \\| | ___ _   _ _ __ ___  "
echo " |  < | |/ _\` | . \` |/ _ \\ | | | '__/ _ \\ "
echo " | . \\| | (_| | |\\  |  __/ |_| | | | (_) |"
echo " |_|\\_\\_|\\__,_|_| \\_|\\___|\\__,_|_|  \\___/ "
echo -e "${NC}"
echo "ASD/ADHD Therapy Edu-Games Platform"
echo "======================================"
echo ""

# Step 1: Check prerequisites
info "Checking prerequisites..."

check_cmd() {
    if command -v "$1" &>/dev/null; then
        ok "$1 found ($(command -v "$1"))"
        return 0
    else
        err "$1 not found"
        return 1
    fi
}

MISSING=0
check_cmd docker || MISSING=1
check_cmd "docker compose" 2>/dev/null || check_cmd docker-compose || MISSING=1
check_cmd python3 || MISSING=1
check_cmd node || MISSING=1
check_cmd git || MISSING=1

if [[ "$MISSING" -eq 1 ]]; then
    warn "Some prerequisites are missing. Install them before continuing."
fi

echo ""

# Step 2: Create .env if not exists
if [[ ! -f ".env" ]]; then
    info "Creating .env from template..."
    cp .env.example .env

    # Generate secure keys
    if command -v openssl &>/dev/null; then
        sed -i "s/changeme-generate-with-openssl-rand-hex-32/$(openssl rand -hex 32)/g" .env
    fi
    ok ".env created (edit with your local settings)"
else
    ok ".env already exists"
fi

echo ""

# Step 3: Start infrastructure
info "Starting Docker infrastructure..."
docker compose up -d postgres redis mailpit
sleep 3
ok "PostgreSQL, Redis, Mailpit started"

echo ""

# Step 4: Setup API
info "Setting up API..."
cd "$PROJECT_DIR/api"

if command -v uv &>/dev/null; then
    info "Using uv package manager..."
    uv venv
    source .venv/bin/activate
    uv pip install -e ".[dev]"
elif command -v pip &>/dev/null; then
    info "Using pip..."
    python3 -m venv venv
    source venv/bin/activate
    pip install -e ".[dev]"
fi
ok "API dependencies installed"

cd "$PROJECT_DIR"
echo ""

# Step 5: Run migrations
info "Running database migrations..."
cd "$PROJECT_DIR/api"
alembic upgrade head 2>/dev/null || warn "Migrations skipped (create first with: ./bin/db makemigration init)"
cd "$PROJECT_DIR"
ok "Database ready"

echo ""

# Step 6: Setup mobile (optional)
read -rp "Setup Expo mobile app? (y/N) " setup_mobile
if [[ "$setup_mobile" =~ ^[Yy]$ ]]; then
    info "Installing mobile dependencies..."
    cd "$PROJECT_DIR/mobile"
    if command -v pnpm &>/dev/null; then
        pnpm install
    else
        npm install
    fi
    cd "$PROJECT_DIR"
    ok "Mobile dependencies installed"
fi

echo ""

# Step 7: Setup web dashboard (optional)
read -rp "Setup Next.js web dashboard? (y/N) " setup_web
if [[ "$setup_web" =~ ^[Yy]$ ]]; then
    info "Installing web dependencies..."
    cd "$PROJECT_DIR/web"
    if command -v pnpm &>/dev/null; then
        pnpm install
    else
        npm install
    fi
    cd "$PROJECT_DIR"
    ok "Web dependencies installed"
fi

echo ""
echo -e "${GREEN}======================================"
echo "  Setup Complete!"
echo "======================================${NC}"
echo ""
echo "Quick Start:"
echo "  ./bin/ctl start       Start infrastructure"
echo "  ./bin/api dev         Start API server (localhost:8000)"
echo "  ./bin/expo dev        Start Expo dev server"
echo "  ./bin/db seed         Seed demo data"
echo ""
echo "Other Commands:"
echo "  ./bin/ctl status      Check service health"
echo "  ./bin/db shell        Open database shell"
echo "  ./bin/api routes      List API routes"
echo "  ./bin/deploy all      Build & push Docker images"
echo ""
echo "Documentation:"
echo "  API Docs:     http://localhost:8000/docs"
echo "  Mail UI:      http://localhost:8025"
echo "  Dashboard:    http://localhost:3000 (after setup)"
echo ""
