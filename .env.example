# =============================================================================
# KidNeuro Godot - Environment Configuration Template
# Copy this file to .env (development) or .env.prod (production)
# =============================================================================

# Application
APP_NAME=kidneuro
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
WEB_URL=http://localhost:3000

# Docker
COMPOSE_PROJECT_NAME=kidneuro-dev
IMAGE_TAG=latest

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=kidneuro
POSTGRES_PASSWORD=kidneuro_dev_password
POSTGRES_DB=kidneuro_dev
DATABASE_URL=postgresql+asyncpg://kidneuro:kidneuro_dev_password@localhost:5432/kidneuro_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password
REDIS_URL=redis://:redis_dev_password@localhost:6379/0

# JWT
JWT_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=changeme-generate-with-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# SMTP (dev: use mailpit or mailtrap)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="KidNeuro Dev <noreply@localhost>"

# Expo
EXPO_ACCESS_TOKEN=
EXPO_PROJECT_ID=

# Sentry (optional in dev)
SENTRY_DSN=

# Logging
LOG_LEVEL=debug
LOG_FORMAT=text
